{
  "name": "agentforge",
  "module": "src/main.tsx",
  "type": "module",
  "private": true,
  "bin": {
    "agentforge": "./src/main.tsx"
  },
  "scripts": {
    "dev": "bun --watch src/main.tsx",
    "start": "bun src/main.tsx",
    "build": "bun build src/main.tsx --compile --outfile agentforge",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "golden": "bun scripts/golden-e2e.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "glob": "^13.0.6",
    "ink": "^5",
    "ink-text-input": "^6",
    "marked": "^18.0.5",
    "openai": "^6.45.0",
    "react": "^18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/bun": "latest",
    "@types/react": "^18",
    "@vitest/coverage-v8": "^4.1.10",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
